# Configuración del backend Fricción Cero (copiar a .env y ajustar)
# Valor hora usado para estimar el costo mensual.
FRICCION_HOURLY_RATE=20.0
# URL de la base de datos (por defecto SQLite local).
FRICCION_DATABASE_URL=sqlite:///./friccion_cero.db
# Sembrar datos de ejemplo al iniciar si la DB está vacía.
FRICCION_SEED_ON_STARTUP=true
